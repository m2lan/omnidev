# =============================================================================
# OmniDev AI Platform — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# All variables can also be set as OS environment variables (same names).
# =============================================================================

# --- App ---
APP_ENV=development
APP_DEBUG=true
APP_PORT=9090
APP_LOG_LEVEL=debug

# --- Database (PostgreSQL) ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=omnidev
DB_PASSWORD=omnidev
DB_NAME=omnidev
DB_SSLMODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=5m

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# --- Kafka ---
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=omnidev

# --- MinIO (S3-compatible storage) ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false

# --- Elasticsearch ---
ES_URL=http://localhost:9200

# --- Temporal ---
TEMPORAL_HOST=localhost:7233

# --- JWT ---
JWT_SECRET=change-me-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h
JWT_ISSUER=omnidev

# --- AI Provider Keys ---
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODELS=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
DEEPSEEK_MODELS=
QWEN_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODELS=

# --- AI Defaults ---
AI_DEFAULT_MODEL=deepseek-chat

# --- RAG Embedding ---
# Provider: openai | gemini | ollama
RAG_EMBEDDING_PROVIDER=openai
# Model name (provider-specific)
RAG_EMBEDDING_MODEL=text-embedding-3-small
# API key override (optional, falls back to provider key above)
RAG_EMBEDDING_API_KEY=
# Base URL for self-hosted / Ollama / vLLM (optional)
RAG_EMBEDDING_BASE_URL=

# --- Security ---
ENCRYPTION_KEY=

# --- OAuth ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URL=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=

# --- Tika (document parsing) ---
TIKA_ENDPOINT=http://localhost:9998
TIKA_TIMEOUT=30
