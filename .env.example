# =============================================================================
# OmniDev AI Platform — Environment Variables
# Copy to .env and update values
# =============================================================================

# --- App ---
APP_NAME=omnidev
APP_ENV=development
APP_DEBUG=true
APP_LOG_LEVEL=debug
APP_PORT=8080

# --- PostgreSQL ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=omnidev
DB_PASSWORD=omnidev
DB_NAME=omnidev
DB_SSLMODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=5m

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_MAX_RETRIES=3
REDIS_POOL_SIZE=10

# --- Kafka ---
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=omnidev
KAFKA_AUTO_OFFSET_RESET=earliest

# --- MinIO ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
MINIO_BUCKET_PREFIX=omnidev

# --- Elasticsearch ---
ES_URL=http://localhost:9200
ES_INDEX_PREFIX=omnidev

# --- Temporal ---
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=omnidev

# --- JWT ---
JWT_SECRET=change-me-in-production-use-at-least-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h
JWT_ISSUER=omnidev

# --- AI Providers ---
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODELS=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
DEEPSEEK_MODELS=
QWEN_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
AI_DEFAULT_MODEL=

# --- OAuth ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URL=http://localhost:8080/api/v1/auth/callback/github
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/api/v1/auth/callback/google

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Email (SMTP) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@omnidev.dev

# --- Monitoring ---
PROMETHEUS_PORT=9090
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# --- Sandbox ---
SANDBOX_RUNTIME_IMAGE=omnidev/sandbox:latest
SANDBOX_CPU_LIMIT=2
SANDBOX_MEMORY_LIMIT=2Gi
SANDBOX_TIMEOUT=300s

# Security - API key encryption (base64-encoded 32-byte key, generate with: openssl rand -base64 32)
OMNIDEV_ENCRYPTION_KEY=